  "descriptions": [
    {
      "description": "This repository provides a multilingual, FAIR-compliant, and project-oriented template for implementing standardized on-farm crop trial protocols using the tricot (Triadic Comparison of Technologies) approach. It includes SOPs, survey templates, core trait definitions, and documentation aligned with DataCite and Crop Ontology standards. The structure enables efficient version control, Zenodo integration, and reuse across crops and languages.",
      "descriptionType": "Abstract"
    }
  ],
